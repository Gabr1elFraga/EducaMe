# Activates the Supabase profile when you want to use the managed backend.
SPRING_PROFILES_ACTIVE=supabase

# Supabase Postgres connection. For IPv4-only networks, use the Session Pooler string from the dashboard.
# The session pooler user usually looks like: postgres.<project-ref>
SUPABASE_DB_URL=jdbc:postgresql://aws-<region>.pooler.supabase.com:5432/postgres
SUPABASE_DB_USER=postgres.<project-ref>
SUPABASE_DB_PASSWORD=replace-me

# Supabase Auth JWT verification endpoints.
SUPABASE_JWT_ISSUER=https://<project-ref>.supabase.co/auth/v1
SUPABASE_JWKS_URI=https://<project-ref>.supabase.co/auth/v1/.well-known/jwks.json
# Required when Supabase is using the default HS256 JWT signing secret.
SUPABASE_JWT_SECRET=replace-me

# Optional if later you need server-side admin access to Supabase APIs.
# Keep this in local env files or deployment secrets only.
# SUPABASE_SERVICE_ROLE_KEY=replace-me
